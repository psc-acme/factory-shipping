{
    "name": "psc-acme/factory-shipping",
    "description": "Package factory-shipping for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\FactoryShipping\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "firebase/php-jwt": "^6.0",
        "illuminate/support": "^11.0",
        "brick/date-time": "^0.7.1",
        "nette/utils": "^4.0",
        "symfony/http-foundation": "^7.0"
    },
    "require-dev": {
        "vimeo/psalm": "^5.0",
        "rector/rector": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}